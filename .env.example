# HTTP
# Puertos poco comunes por defecto para no chocar con servicios locales
# típicos (3000, 5432, 9092). Cámbialos si lo necesitas.
PORT=3717

# Base de datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5477
DB_USER=quotas
DB_PASSWORD=change-me
DB_NAME=ms_quotas
# Solo para desarrollo/prueba técnica; en producción usar migraciones
DB_SYNCHRONIZE=true

# JWT
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=1h

# Event bus: kafka | stub
EVENT_BUS=kafka
KAFKA_BROKERS=localhost:9377
KAFKA_CLIENT_ID=ms-quotas
# Puerto del broker expuesto en el host por docker-compose
KAFKA_EXTERNAL_PORT=9377

# Reglas de negocio
OVERDUE_PENALTY_RATE=0.15
QUOTA_INTERVAL_DAYS=30
